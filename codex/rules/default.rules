prefix_rule(pattern=["git", "checkout", "-b"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "checks"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")
prefix_rule(pattern=["git", "add", "AGENTS.md"], decision="allow")
prefix_rule(pattern=["git", "cherry-pick"], decision="allow")
prefix_rule(pattern=["bun", "install"], decision="allow")
prefix_rule(pattern=["gh", "issue", "create"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["git", "fetch", "origin"], decision="allow")
prefix_rule(pattern=["gh", "run"], decision="allow")
prefix_rule(pattern=["uv", "run", "pytest"], decision="allow")
prefix_rule(pattern=["uv", "run", "ruff"], decision="allow")
prefix_rule(pattern=["uv", "run", "pre-commit"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
